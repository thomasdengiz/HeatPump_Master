<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FR_Options">

    <!-- ScrollView for vertical scrolling -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <!-- ConstraintLayout inside ScrollView -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/button_game"
                android:layout_width="145dp"
                android:layout_height="80dp"
                android:layout_marginTop="25dp"
                android:textSize="12sp"
                android:text="@string/start_game"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/button_options"
                android:layout_width="145dp"
                android:layout_height="80dp"
                android:layout_marginTop="50dp"
                android:text="@string/options"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="@+id/button_game"
                app:layout_constraintHorizontal_bias="0.444"
                app:layout_constraintStart_toStartOf="@+id/button_game"
                app:layout_constraintTop_toBottomOf="@+id/button_game" />

            <Button
                android:id="@+id/button_level_selection"
                android:layout_width="145dp"
                android:layout_height="80dp"
                android:textSize="12sp"
                android:text="@string/level_selection"
                android:layout_marginTop="50dp"
                app:layout_constraintEnd_toEndOf="@+id/button_options"
                app:layout_constraintStart_toStartOf="@+id/button_options"
                app:layout_constraintTop_toBottomOf="@+id/button_options" />

            <Button
                android:id="@+id/button_how_to_play"
                android:layout_width="145dp"
                android:layout_height="80dp"
                android:layout_marginTop="50dp"
                android:text="@string/how_to_play"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="@+id/button_game"
                app:layout_constraintHorizontal_bias="0.444"
                app:layout_constraintStart_toStartOf="@+id/button_game"
                app:layout_constraintTop_toBottomOf="@+id/button_level_selection" />

            <Button
                android:id="@+id/button_facts"
                android:layout_width="145dp"
                android:layout_height="80dp"
                android:textSize="12sp"
                android:layout_marginTop="50dp"
                android:text="@string/interesting_facts"
                app:layout_constraintEnd_toEndOf="@+id/button_game"
                app:layout_constraintHorizontal_bias="0.444"
                app:layout_constraintStart_toStartOf="@+id/button_game"
                app:layout_constraintTop_toBottomOf="@+id/button_how_to_play" />

            <Button
                android:id="@+id/button_exit"
                android:layout_width="145dp"
                android:layout_height="80dp"
                android:layout_marginTop="50dp"
                android:textSize="11sp"
                android:text="@string/exit"
                app:layout_constraintEnd_toEndOf="@+id/button_game"
                app:layout_constraintHorizontal_bias="0.444"
                app:layout_constraintStart_toStartOf="@+id/button_game"
                app:layout_constraintTop_toBottomOf="@+id/button_facts" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</FrameLayout>
